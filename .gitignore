# Dependencies
/node_modules
/vendor

# Build artifacts. Compiled blocks land in /build (block.json auto-discovered from
# assets/src/blocks and built by `npm run build`); regenerated locally and in CI.
/build
/dist
/.release
*.zip

# Lock files. package-lock.json IS committed (npm ci needs it for reproducible builds);
# Composer/yarn are unused here.
/composer.lock
/yarn.lock

# Environment & secrets
.env
.env.*

# OS & editor
.DS_Store
Thumbs.db
.idea
.vscode
